authentication apex-auth (
    name: APEX Auth
    type: oracleApexAccounts
    postLogout {
        redirectTo: url
        url: f?p=&APP_ID.:1
    }
)

authentication no-auth (
    name: No Auth
    type: noAuth
    settings {
        username: Public User
    }
)

authentication open-door-access (
    name: Open Door Access
    type: openDoorCredentials
)

